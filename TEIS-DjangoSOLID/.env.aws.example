# .env.aws - Configuración para AWS EC2
# Copiar a .env antes de ejecutar en AWS

# ========== DJANGO ==========
SECRET_KEY=change-me-to-a-very-long-random-string-in-production
DEBUG=False
ALLOWED_HOSTS=ec2-YOUR-PUBLIC-IP.compute.amazonaws.com,YOUR-PUBLIC-IP

# ========== BASE DE DATOS (PostgreSQL en EC2) ==========
DB_ENGINE=django.db.backends.postgresql
DB_NAME=tienda_db
DB_USER=postgres
DB_PASSWORD=PostgresPassword123!
DB_HOST=localhost
DB_PORT=5432

# ========== PAGOS ==========
PAYMENT_PROVIDER=REAL

# ========== LOGS ==========
LOG_LEVEL=INFO
